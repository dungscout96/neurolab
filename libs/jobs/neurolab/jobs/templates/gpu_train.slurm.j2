#!/usr/bin/env bash
{# Template for GPU training jobs on HPC clusters.
   Renders a complete SLURM script with environment setup,
   directory creation, and a training command.

   Variables:
     job_name, partition, account, gpus, cpus, mem_gb, time_limit,
     env_setup, working_dir, command, log_dir
#}
#SBATCH --job-name={{ job_name }}
#SBATCH --partition={{ partition }}
#SBATCH --account={{ account }}
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task={{ cpus | default(8) }}
#SBATCH --gpus={{ gpus | default(1) }}
#SBATCH --mem={{ mem_gb | default(64) }}G
#SBATCH --time={{ time_limit | default("02:00:00") }}
#SBATCH --output={{ log_dir | default("logs") }}/{{ job_name }}_%j.out
#SBATCH --error={{ log_dir | default("logs") }}/{{ job_name }}_%j.err
{% if qos %}#SBATCH --qos={{ qos }}{% endif %}
{% if dependency %}#SBATCH --dependency={{ dependency }}{% endif %}

# ── Environment setup ──
{{ env_setup }}

# ── Ensure directories ──
mkdir -p {{ log_dir | default("logs") }}

{% if working_dir %}
cd {{ working_dir }}
{% endif %}

echo "=== Job $SLURM_JOB_ID starting on $(hostname) at $(date) ==="
echo "GPUs: $CUDA_VISIBLE_DEVICES"
echo ""

# ── Training command ──
{{ command }}

echo ""
echo "=== Job $SLURM_JOB_ID finished at $(date) ==="
